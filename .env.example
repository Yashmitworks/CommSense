# CommSense — Environment Configuration
# Copy this file to .env and fill in your key

# Groq API key — get yours FREE at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# LLM provider — set to "groq"
LLM_PROVIDER=groq

# Session settings
SESSION_LOG_DIR=data/session_logs
REPORT_OUTPUT_DIR=data/reports
